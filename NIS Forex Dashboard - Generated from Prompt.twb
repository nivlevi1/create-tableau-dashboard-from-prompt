    <worksheet name='Multi-Currency Comparison'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Bold' fontsize='11'>Multi-Currency Comparison</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='NIS Exchange Rates' name='textscan.nisexchange001' />

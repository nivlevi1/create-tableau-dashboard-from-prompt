          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' domain-expand='false' field='[textscan.nisexchange001].[avg:Calculation_1000000000000000001:qk]' field-type='quantitative' major-origin='0.0' major-spacing='0.10000000000000001' minor-origin='0.0' minor-spacing='0.01' scope='rows' type='space' />
            <encoding attr='space' class='1' field='[textscan.nisexchange001].[avg:Calculation_1000000000000000001:qk]' field-type='quantitative' fold='true' scope='rows' synchronized='true' type='space' />
            <format attr='display' class='1' field='[textscan.nisexchange001].[avg:Calculation_1000000000000000001:qk]' scope='rows' value='false' />
            <format attr='title' class='0' field='[textscan.nisexchange001].[avg:Calculation_1000000000000000001:qk]' scope='rows' value='' />

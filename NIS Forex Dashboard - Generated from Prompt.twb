      <aliases enabled='yes' />
      <column caption='CHF' datatype='real' name='[CHF]' role='measure' type='quantitative' />
      <column caption='Cumulative % Change' datatype='real' name='[Calculation_0697156532551683]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(&#13;&#10;    (AVG([Calculation_1000000000000000001]) - LOOKUP(AVG([Calculation_1000000000000000001]), FIRST()))&#13;&#10;    / ABS(LOOKUP(AVG([Calculation_1000000000000000001]), FIRST()))&#13;&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Selected Rate' datatype='real' name='[Calculation_1000000000000000001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1] WHEN &quot;USD&quot; THEN [USD] WHEN &quot;GBP&quot; THEN [GBP] WHEN &quot;JPY_100&quot; THEN [JPY_100] WHEN &quot;EUR&quot; THEN [EUR] WHEN &quot;CHF&quot; THEN [CHF] END' />
      </column>
      <column caption='Selected Date (Dynamic)' datatype='string' name='[Calculation_1000000000000000002]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Day&quot; THEN &#13;&#10;    STR(YEAR([Date])) + &quot;-&quot; +&#13;&#10;    RIGHT(&quot;0&quot; + STR(MONTH([Date])),2) + &quot;-&quot; +&#13;&#10;    RIGHT(&quot;0&quot; + STR(DAY([Date])),2)&#13;&#10;&#13;&#10;WHEN &quot;Week&quot; THEN &#13;&#10;    STR(YEAR([Date])) + &quot;-W&quot; +&#13;&#10;    RIGHT(&quot;0&quot; + STR(DATEPART(&apos;week&apos;,[Date])),2)&#13;&#10;&#13;&#10;WHEN &quot;Month&quot; THEN &#13;&#10;    STR(YEAR([Date])) + &quot;-&quot; +&#13;&#10;    RIGHT(&quot;0&quot; + STR(MONTH([Date])),2)&#13;&#10;&#13;&#10;WHEN &quot;Quarter&quot; THEN &#13;&#10;    STR(YEAR([Date])) + &quot;-Q&quot; +&#13;&#10;    STR(DATEPART(&apos;quarter&apos;,[Date]))&#13;&#10;&#13;&#10;WHEN &quot;Year&quot; THEN &#13;&#10;    STR(YEAR([Date]))&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Date In Range' datatype='boolean' name='[Calculation_1000000000000000003]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Date] &gt;= [Parameters].[Parameter 3] AND [Date] &lt;= [Parameters].[Parameter 4]' />
      </column>
      <column caption='Period Change %' datatype='real' default-format='p1%' name='[Calculation_1000000000000000004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN((LOOKUP(AVG([Calculation_1000000000000000001]), 0) - LOOKUP(AVG([Calculation_1000000000000000001]), -1)) / ABS(LOOKUP(AVG([Calculation_1000000000000000001]), -1)))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Month Name' datatype='string' name='[Calculation_1000000000000000005]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [Date])' />
      </column>
      <column caption='Month Number' datatype='integer' name='[Calculation_1000000000000000006]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MONTH([Date])' />
      </column>
      <column caption='Day of Week' datatype='string' name='[Calculation_1000000000000000007]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [Date])' />
      </column>
      <column caption='Day Number' datatype='integer' name='[Calculation_1000000000000000008]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;weekday&apos;, [Date])' />
      </column>
      <column caption='Period Label' datatype='string' name='[Calculation_1000000000000000009]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2] WHEN &quot;Year&quot; THEN STR(YEAR([Calculation_1000000000000000002])) WHEN &quot;Quarter&quot; THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;,[Calculation_1000000000000000002])) + &quot;-&quot; + STR(YEAR([Calculation_1000000000000000002])) WHEN &quot;Month&quot; THEN RIGHT(&quot;0&quot; + STR(MONTH([Calculation_1000000000000000002])), 2) + &quot;-&quot; + STR(YEAR([Calculation_1000000000000000002])) WHEN &quot;Week&quot; THEN &quot;W&quot; + RIGHT(&quot;0&quot; + STR(DATEPART(&apos;week&apos;,[Calculation_1000000000000000002])), 2) + &quot;-&quot; + STR(YEAR([Calculation_1000000000000000002])) WHEN &quot;Day&quot; THEN STR(MONTH([Calculation_1000000000000000002])) + &quot;/&quot; + STR(DAY([Calculation_1000000000000000002])) + &quot;/&quot; + STR(YEAR([Calculation_1000000000000000002])) END' />
      </column>
      <column caption='Date' datatype='date' name='[Date]' role='dimension' type='ordinal' />
      <column caption='EUR' datatype='real' name='[EUR]' role='measure' type='quantitative' />
      <column caption='GBP' datatype='real' name='[GBP]' role='measure' type='quantitative' />
      <column caption='JPY/100' datatype='real' name='[JPY_100]' role='measure' type='quantitative' />

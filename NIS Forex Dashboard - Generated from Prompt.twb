              <groupfilter function='member' level='[:Measure Names]' member='&quot;[textscan.nisexchange001].[avg:CHF:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[textscan.nisexchange001].[avg:EUR:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[textscan.nisexchange001].[avg:GBP:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[textscan.nisexchange001].[avg:JPY_100:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[textscan.nisexchange001].[avg:USD:qk]&quot;' />

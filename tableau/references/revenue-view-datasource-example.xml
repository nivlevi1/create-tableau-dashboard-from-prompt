<!-- 
  Revenue view (Databricks) Datasource Example
  Extracted from a production KPI Tracking workbook
  
  This is a complete example of a published data source connection using sqlproxy
  Key patterns:
  - Datasource name: sqlproxy.<long_id>
  - Repository location with derived-from
  - Full path format: /t/{site}/datasources
  - Connection with all attributes
  - Relation type='collection' with multiple relations
  - Calculations defined in datasource
  - Metadata-records structure
-->
<datasource caption="Revenue view (Databricks)" inline="true" name="sqlproxy.0xloa3o1j494z91a039qy0nm99ru" version="18.1">
  <!-- Repository location points to the published data source on Tableau Cloud -->
  <repository-location derived-from="/datasources/YourDatasource-fixed?rev=1.0" 
                       id="YourRevenueView" 
                       path="/t/your-site-name/datasources" 
                       revision="4.6" 
                       site="your-site-name" />
  
  <!-- sqlproxy connection to Tableau Cloud -->
  <connection channel="https" 
              class="sqlproxy" 
              dbname="YourRevenueView" 
              directory="/dataserver" 
              local-dataserver="" 
              port="443" 
              server="your-pod.online.tableau.com" 
              server-oauth="" 
              username="" 
              workgroup-auth-mode="prompt">
    
    <!-- Relation structure: type='collection' with multiple nested relations -->
    <relation type="collection">
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
      <relation name="sqlproxy" table="[sqlproxy]" type="table" />
    </relation>
    
    <!-- Calculations defined in the datasource connection -->
    <calculations>
      <calculation column="[% New Approval Rate (copy) (copy)_1125958571053087]" 
                   formula="[Approved New Orders (copy)_1125958570176539]/[Approved Renew Orders (copy)_1125958570315804]" />
      <calculation column="[% New Approval Rate (copy)_1125958571044894]" 
                   formula="[Calculation_1125958568550425]/[Approved Renew Orders (copy)_1125958570315804]" />
      <calculation column="[ARPU (copy)_1125958586908724]" 
                   formula="[Net New Orders (copy)_1125958555062294]/&#10;[Net Orders (copy)_14636757102506014]" />
      <calculation column="[ARPU (copy)_1213368290106335233]" 
                   formula="COUNTD(&#10;IF [refund_type] &lt;&gt; &apos;NONE&apos;&#10;AND [order_status] &lt;&gt; &apos;UNPAID&apos;&#10;THEN [order_id]&#10;END&#10;)&#10;&#10;/&#10;&#10;COUNTD( IF  [order_status] &lt;&gt; &apos;UNPAID&apos;&#10; THEN&#10;[order_id]&#10;END&#10;)" />
      <calculation column="[Approved New Orders (copy)_1125958570176539]" 
                   formula="COUNTD(IF  &#10;[order_status] &lt;&gt;&apos;FAILED&apos;&#10;AND [order_status] &lt;&gt;&apos;PENDING&apos; &#10;AND  [order_action] = &apos;RENEWAL&apos;&#10;THEN [order_id] END)" />
      <calculation column="[Gross Collection (copy)_14636757085798420]" 
                   formula="SUM(&#10;    IF [order_status] = &quot;COMPLETED&quot;&#10;        AND [refund_type] = &apos;NONE&apos;&#10;       AND [payment_gateway] &lt;&gt; &quot;UNKNOWN&quot;&#10;       AND [payment_gateway] &lt;&gt; &quot;MANUAL&quot;&#10;    THEN [usd_net_total]&#10;    END&#10;)" />
      <!-- Note: The actual datasource has 59+ calculations - this is a sample -->
    </calculations>
    
    <!-- Metadata records define all fields (columns and calculated measures) -->
    <metadata-records>
      <!-- Example: Calculated Measure -->
      <metadata-record class="measure">
        <remote-name>% New Approval Rate (copy) (copy)_1125958571053087</remote-name>
        <remote-type>-1</remote-type>
        <local-name>[% New Approval Rate (copy) (copy)_1125958571053087]</local-name>
        <parent-name>[sqlproxy]</parent-name>
        <remote-alias>% New Approval Rate (copy) (copy)_1125958571053087</remote-alias>
        <ordinal>215</ordinal>
        <layered>true</layered>
        <caption>% Renewal Approval Rate</caption>
        <local-type>real</local-type>
        <aggregation>User</aggregation>
        <contains-null>true</contains-null>
        <attributes>
          <attribute datatype="integer" name="field-type">0</attribute>
          <attribute datatype="string" name="formula">"[Approved New Orders (copy)_1125958570176539]/[Approved Renew Orders (copy)_1125958570315804]"</attribute>
        </attributes>
      </metadata-record>
      
      <!-- Example: Calculated Column (Date) -->
      <metadata-record class="column">
        <remote-name>Calculation_1125962014507072</remote-name>
        <remote-type>-1</remote-type>
        <local-name>[Calculation_1125962014507072]</local-name>
        <parent-name>[sqlproxy]</parent-name>
        <remote-alias>Calculation_1125962014507072</remote-alias>
        <ordinal>233</ordinal>
        <layered>true</layered>
        <caption>Order Date</caption>
        <local-type>date</local-type>
        <aggregation>Year</aggregation>
        <contains-null>true</contains-null>
        <attributes>
          <attribute datatype="integer" name="field-type">1</attribute>
          <attribute datatype="string" name="formula">"[paid_date]"</attribute>
          <attribute datatype="integer" name="role">0</attribute>
        </attributes>
        <object-id>[order_items_status (your-catalog.marts.order_items_status)_8CD1169DBCB64A8B8A46356B0F3C7D3A]</object-id>
      </metadata-record>
      
      <!-- Note: The actual datasource has 200+ metadata-records for all columns and calculations -->
    </metadata-records>
  </connection>
</datasource>

<!-- 
  KEY ATTRIBUTES EXPLAINED:
  
  datasource:
  - caption: Display name shown in Tableau Desktop
  - name: Unique identifier format sqlproxy.<long_id>
  - inline: true (indicates this is a connection, not embedded data)
  - version: Tableau workbook version (18.1 = 2025.3)
  
  repository-location:
  - derived-from: Full URL to published data source (optional but useful)
  - id: Published data source content URL (must match dbname in connection)
  - path: Full path format /t/{site}/datasources
  - revision: Version number of the published data source
  - site: Tableau site name
  
  connection:
  - channel: https (for Tableau Cloud)
  - class: sqlproxy (CRITICAL - identifies published data source)
  - dbname: Must match repository-location id
  - directory: Always /dataserver
  - local-dataserver: Empty for cloud connections
  - port: 443 for HTTPS
  - server: Tableau Cloud pod hostname
  - server-oauth: Usually empty
  - username: Empty for published data sources
  - workgroup-auth-mode: prompt (user prompted) or as-is
  
  relation:
  - type: collection (wraps multiple relations)
  - name: Always sqlproxy
  - table: Always [sqlproxy]
  - type: table (for nested relations)
  
  calculations:
  - column: Field name in brackets
  - formula: Tableau calculation formula (XML entities escaped)
  
  metadata-records:
  - class: measure or column
  - parent-name: Always [sqlproxy] for published data sources
  - layered: true for calculated fields
  - aggregation: User (calculated), Sum, Count, etc.
-->
